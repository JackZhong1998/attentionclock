    "开启桌面伙伴后，可从图鉴下载角色陪你专注，或显示在桌面上。": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启桌面伙伴后，可从图鉴下载角色陪你专注，或显示在桌面上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟桌面伙伴後，可从圖鉴下載角色陪你專注，或顯示在桌面上。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable desktop companions to download characters from the catalog, keep you company while focusing, or show one on your desktop."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "有効にすると、図鑑からキャラをダウンロードして集中を一緒にしたり、デスクトップに表示できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜면 도감에서 캐릭터를 받아 집중할 때 함께하거나 바탕화면에 표시할 수 있습니다."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Actívalo para descargar personajes del catálogo, acompañarte al enfocarte o mostrarlos en el escritorio."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez pour télécharger des personnages, vous tenir compagnie pendant le focus ou les afficher sur le bureau."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren, um Charaktere aus dem Katalog zu laden, beim Fokussieren Gesellschaft zu leisten oder sie auf dem Desktop anzuzeigen."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ative para baixar personagens do catálogo, fazer companhia no foco ou exibir na área de trabalho."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включите, чтобы скачивать персонажей из каталога, сопровождать вас во время фокуса или показывать на рабочем столе."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "فعّل لتحميل الشخصيات من الفهرس، مرافقتك أثناء التركيز، أو عرضها على سطح المكتب."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कैटलॉग से पात्र डाउनलोड करने, फ़ोकस में साथ देने या डेस्कटॉप पर दिखाने के लिए चालू करें।"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Attiva per scaricare personaggi dal catalogo, farti compagnia durante il focus o mostrarli sul desktop."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เปิดใช้เพื่อดาวน์โหลดตัวละครจากคatalog คอยเป็นเพื่อนตอนโฟกัส หรือแสดงบนเดสก์ท็อป"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bật để tải nhân vật từ danh mục, đồng hành khi tập trung hoặc hiển thị trên màn hình."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktifkan untuk mengunduh karakter dari katalog, menemani fokus, atau menampilkannya di desktop."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Katalogdan karakter indirmek, odaklanırken eşlik etmek veya masaüstünde göstermek için etkinleştirin."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Schakel in om personages uit de catalogus te downloaden, gezelschap te houden tijdens focus of op het bureaublad te tonen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Włącz, aby pobierać postacie z katalogu, towarzyszyć podczas skupienia lub wyświetlać na pulpicie."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Увімкніть, щоб завантажувати персонажів із каталогу, супроводжувати під час фокусу або показувати на робочому столі."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Dayakan untuk memuat turun watak dari katalog, menemani fokus, atau paparkan di desktop."
          }
        }
      }
    }
  },
  "version": "1.0"
}
