    "今天你陪了我 %lld 分钟，好开心！": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You focused with me for %lld minutes today. So happy!"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今日は %lld 分一緒に集中してくれたね、うれしい！"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오늘 %lld분이나 함께 집중해 줘서 정말 기뻐!"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "今天你陪了我 %lld 分鐘，好開心！"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoy te quedaste conmigo durante %lld minutos, ¡muy feliz!"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aujourd'hui, vous êtes resté avec moi pendant %lld minutes, tellement heureux !"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Heute warst du %lld Minuten bei mir, so glücklich!"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoje você ficou comigo por %lld minutos, muito feliz!"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сегодня вы остановились у меня на %lld минут, так счастливы!"
