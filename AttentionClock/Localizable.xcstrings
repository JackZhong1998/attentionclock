          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "पिछले 26 हफ़्तों में हर दिन ध्यान केंद्रित किया गया है, जिसमें गहरे रंग अधिक गतिविधि का संकेत देते हैं"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Focus giornaliero nelle ultime 26 settimane, con colori più scuri che indicano più attività"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ความเข้มข้นรายวันในช่วง 26 สัปดาห์ที่ผ่านมา ยิ่งสีเข้มขึ้นเท่าใดก็ยิ่งมีความกระตือรือร้นมากขึ้นเท่านั้น"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nồng độ hàng ngày trong 26 tuần qua, màu càng đậm thì càng hoạt động"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Fokus harian selama 26 minggu terakhir, dengan warna yang lebih gelap menunjukkan lebih banyak aktivitas"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Son 26 haftadaki günlük konsantrasyon, renk ne kadar koyuysa o kadar aktiftir"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
