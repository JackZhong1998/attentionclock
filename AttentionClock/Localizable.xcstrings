    "虽然没完成，但也陪了我一会儿～": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Didn't finish, but thanks for keeping me company~"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "完了しなくても、少し一緒にいてくれたね～"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "완료하진 못했지만, 잠깐 함께해 줘서 고마워~"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "雖然沒完成，但也陪了我一會兒～"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aunque no está terminado, pero también me acompañó por un tiempo ~"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bien qu'il ne soit pas terminé, mais m'a également accompagné pendant un certain temps ~"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Obwohl es nicht abgeschlossen ist, sondern mich auch eine Weile begleitet hat ~"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Embora não esteja concluído, mas também me acompanhou por um tempo ~"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Хотя он не завершен, но также некоторое время сопровождал меня ~"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "على الرغم من أنه لم يكتمل، ولكن أيضا رافقني لفترة من الوقت ~"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हालांकि यह पूरा नहीं हुआ है, लेकिन कुछ समय के लिए मेरे साथ भी ~"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Anche se non è completato, ma mi ha anche accompagnato per un po' ~"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "แม้ว่าฉันจะทำงานไม่เสร็จแต่ฉันก็อยู่กับฉันสักพัก~"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mặc dù tôi chưa hoàn thành nó nhưng tôi đã ở lại với tôi một lúc ~"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Meskipun saya tidak menyelesaikannya, saya tetap bersama saya untuk sementara waktu~"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitirmememe rağmen bir süre yanımda kaldım~"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Hoewel ik het niet afmaakte, bleef ik een tijdje bij me~"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Choć nie dokończyłam, zostałam ze sobą na jakiś czas~"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Хоча я не закінчив його, я залишився зі собою на деякий час~"
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Walaupun saya tidak menyelesaikannya, saya tinggal bersama saya untuk seketika~"
          }
        }
      }
    },
