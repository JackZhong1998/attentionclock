        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "過去 26 周每日專注情况，顏色越深表示越活躍"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Enfoque diario en las últimas 26 semanas, con colores más oscuros que indican más actividad"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Concentration quotidienne au cours des 26 dernières semaines, avec des couleurs plus foncées indiquant plus d'activité"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Täglicher Fokus in den letzten 26 Wochen, wobei dunklere Farben auf mehr Aktivität hinweisen"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Foco diário nas últimas 26 semanas, com cores mais escuras indicando mais atividade"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ежедневный фокус за последние 26 недель, с более темными цветами, указывающими на большую активность"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
