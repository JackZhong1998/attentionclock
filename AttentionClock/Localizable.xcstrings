    "点「开始专注」陪我吧": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap Start Focus to join me"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「集中を開始」を押してね"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "「집중 시작」을 눌러줘"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點「開始專注」陪我吧"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pulsa \"Empieza a centrarte\" para acompañarme"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Appuyez sur « Commencer à me concentrer » pour m'accompagner"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe auf „Fokussierung starten“, um mich zu begleiten."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque em \"Começar a focar\" para me acompanhar"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажмите «Начать фокусировку», чтобы сопровождать меня"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اضغط على \"بدء التركيز\" لمرافقتي"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "मेरा साथ देने के लिए \"फ़ोकस करना शुरू करें\" पर टैप करें"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca \"Inizia a concentrarti\" per accompagnarmi"
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คลิก \"เริ่มโฟกัส\" เพื่อติดตามฉัน"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bấm \"Bắt đầu lấy nét\" để đồng hành cùng tôi"
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Klik \"Mulai Fokus\" untuk menemani saya"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bana eşlik etmek için \"Odaklanmaya Başla\"ya tıklayın"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Klik op 'Start focussen' om met mij mee te gaan"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
