          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non mostrare alcuna caratteristica relativa al gatto quando è spento."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "หลังจากปิดแล้ว จะไม่แสดงฟังก์ชันที่เกี่ยวข้องกับแมว"
