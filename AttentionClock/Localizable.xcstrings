    "关闭后不显示任何养猫相关功能。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When off, all cat companion features are hidden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフにすると猫関連の機能は表示されません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "끄면 고양이 관련 기능이 모두 숨겨집니다."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "關闭後不顯示任何养貓相關功能。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No muestre ninguna característica relacionada con el CAT cuando esté apagado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne montrez aucune caractéristique liée au chat lorsqu'il est éteint."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zeigen Sie keine katzenbezogenen Funktionen an, wenn Sie ausgeschaltet sind."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não mostre nenhum recurso relacionado ao Cat quando desligado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "При выключении не показывайте никаких функций, связанных с CAT."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا تعرض أي ميزات متعلقة بالقطط عند إيقاف التشغيل."
